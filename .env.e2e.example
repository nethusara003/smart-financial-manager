# E2E-safe environment values (no secrets)
# Copy values into your local shell or CI secret store as needed.

NODE_ENV=test
BACKEND_PORT=5000
FRONTEND_PORT=5173

# Frontend <-> backend wiring
FRONTEND_URL=http://127.0.0.1:5173
VITE_API_URL=http://127.0.0.1:5000/api

# Test database (local default)
MONGO_URI=mongodb://127.0.0.1:27017/sfm_e2e

# Replace with a secure value in CI secret storage
JWT_SECRET=replace-with-secure-test-secret
