{
  "type": "module",
  "name": "sft-backend",
  "version": "1.0.0",
  "description": "Smart Financial Tracker - Backend API Server",
  "main": "server.js",
  "scripts": {
    "start": "npm run start:api",
    "start:api": "node server.js",
    "start:worker": "node worker.js",
    "smoke:prod": "npm --prefix .. run smoke:prod",
    "smoke:deploy": "npm --prefix .. run smoke:deploy --",
    "dev": "npm run dev:api",
    "dev:api": "nodemon server.js",
    "dev:worker": "nodemon worker.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:retirement:smoke": "node test/retirement-engine-smoke.js",
    "smoke:api": "node test/smoke-api.js",
    "sync:prod-to-local:safe": "node scripts/sync-prod-to-local-safe.js",
    "migrate:transactions:scope": "node migrate-transaction-scope.js",
    "migrate:transactions:scope:dry": "node migrate-transaction-scope.js --dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "chalk": "^5.6.2",
    "chrono-node": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.1",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
