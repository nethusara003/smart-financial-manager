# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/smart_financial_tracker
# Backward-compatible alias used in some scripts:
MONGDB_URI=mongodb://127.0.0.1:27017/smart_financial_tracker

# Optional one-command safe sync source URI (production -> local clone)
PROD_MONGO_URI=
# Optional target for safe local clone. Defaults to mongodb://127.0.0.1:27017/smart_financial_tracker_safe_clone
SAFE_LOCAL_MONGO_URI=

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# OTP Delivery Configuration
# Set true to force email-only OTP and hide phone OTP in UI
OTP_EMAIL_ONLY=false
# Used when users enter local numbers like 0771234567
OTP_DEFAULT_COUNTRY_CODE=94

# Twilio SMS (required only when OTP_EMAIL_ONLY=false)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_PHONE=+1XXXXXXXXXX

# Frontend URL(s) for CORS (comma-separated when multiple origins are needed)
FRONTEND_URL=http://localhost:5173
# Example production value:
# FRONTEND_URL=https://smart-financial-tracker.vercel.app,https://smart-financial-tracker-git-main-nethusara003s-projects.vercel.app

# Admin Configuration
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# Retirement Planning Configuration
RETIREMENT_RETURN_RATE=0.08
RETIREMENT_INFLATION_RATE=0.03
RETIREMENT_SALARY_GROWTH_RATE=0.04
RETIREMENT_MC_SIMULATIONS=1000
RETIREMENT_RETURN_MEAN=0.08
RETIREMENT_RETURN_STD_DEV=0.03
RETIREMENT_INCOME_VARIATION=0.10
RETIREMENT_EXPENSE_VARIATION=0.08
RETIREMENT_ML_SERVICE_URL=http://127.0.0.1:5055
RETIREMENT_ML_TIMEOUT_MS=1200
RETIREMENT_HISTORY_MONTHS=24
RETIREMENT_PROFILE_MONTHS_WINDOW=6
# When true, fallback forecast is disabled and API will return error if ML service is unavailable.
RETIREMENT_REQUIRE_ML=false

# AI Chatbot Configuration - Google Gemini
# Get your API key from: https://aistudio.google.com/app/apikeys
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key
# Available models: gemini-1.5-flash-latest, gemini-1.5-pro-latest, or gemini-2.0-flash-latest (if available with Pro membership)
GEMINI_MODEL=gemini-1.5-flash-latest
# Token limits for primary and retry prompts
GEMINI_PRIMARY_SYSTEM_PROMPT_CHARS=1800
GEMINI_PRIMARY_USER_PROMPT_CHARS=8500
GEMINI_RETRY_SYSTEM_PROMPT_CHARS=900
GEMINI_RETRY_USER_PROMPT_CHARS=2600
GEMINI_PRIMARY_MAX_TOKENS=450
GEMINI_RETRY_MAX_TOKENS=280
