# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/smart_financial_manager

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Configuration
